# Frontend — Supabase (seguro expor com anon key)
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# ATENÇÃO: A chave Anthropic NÃO vai mais aqui.
# Ela deve ser configurada na Edge Function do Supabase:
#   supabase secrets set ANTHROPIC_API_KEY=sua_chave_aqui
# Ou no painel: Supabase > Edge Functions > Secrets
